# ============================================================================
# Order Flow Radar Trading Signal System - Environment Configuration
# ============================================================================
# Copy this file to .env and populate with your actual credentials.
# IMPORTANT: Never commit .env file with real credentials to version control.

# ============================================================================
# ALPACA DATA API - Stock & Crypto Markets
# ============================================================================
# Get credentials from: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ============================================================================
# POLYGON.IO - Supplemental Equity Data
# ============================================================================
# Get API key from: https://polygon.io/
# Free tier: 5 calls/minute
POLYGON_API_KEY=

# ============================================================================
# ALPHA VANTAGE - Technical Indicators & Market Sentiment
# ============================================================================
# Get API key from: https://www.alphavantage.co/
# Free tier: 25 calls/day, 5 calls/minute
ALPHA_VANTAGE_KEY=

# ============================================================================
# CHARLES SCHWAB - Options Flow & Market Data
# ============================================================================
# Get credentials from: https://developer.schwab.com/
# Requires OAuth2 app registration
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REFRESH_TOKEN=

# ============================================================================
# DISCORD - Alert Notifications
# ============================================================================
# Create webhook in Discord server settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ============================================================================
# TRADING SYMBOLS - Comma-separated lists
# ============================================================================
# Default equities: AAPL,TSLA,NVDA,SPY,QQQ,AMD,AMZN,META,MSFT,GOOGL
EQUITY_SYMBOLS=AAPL,TSLA,NVDA,SPY,QQQ,AMD,AMZN,META,MSFT,GOOGL

# Default crypto: BTC/USD,ETH/USD
CRYPTO_SYMBOLS=BTC/USD,ETH/USD

# ============================================================================
# POLLING INTERVALS - Seconds between API updates
# ============================================================================
# Equity quotes & bars polling interval (default: 60 seconds = 1 minute)
EQUITY_POLL_SECONDS=60

# Alpha Vantage technical indicators polling interval (default: 300 = 5 minutes)
# Respects free tier rate limit of 25 calls/day
ALPHA_POLL_SECONDS=300

# Schwab options chain polling interval (default: 300 = 5 minutes)
# Only polls during market hours 9:30-16:00 ET Mon-Fri
SCHWAB_POLL_SECONDS=300

# ============================================================================
# ORDER FLOW DETECTION PARAMETERS
# ============================================================================
# Minimum BTC amount to detect as a "wall" in orderbook (crypto)
# Used to identify large buy/sell walls that could support/resistance
WALL_SIZE_BTC=5.0

# Minimum share quantity to detect as a "wall" in orderbook (equities)
# Used to identify large block orders and structural support/resistance
WALL_SIZE_EQUITY=10000

# ============================================================================
# SIGNAL THRESHOLDS - Confluence Requirements
# ============================================================================
# Bid/Ask imbalance threshold as decimal (0.15 = 15% imbalance)
# Example: If bids are 15% larger than asks, signal triggers
IMBALANCE_THRESHOLD=0.15

# Volume spike multiplier (2.5 = 2.5x recent average volume)
# Detects unusual trading activity that precedes directional moves
VOLUME_SPIKE_MULT=2.5

# VWAP deviation threshold as decimal (0.02 = 2% deviation)
# Identifies when price strays from volume-weighted average price
VWAP_DEV_THRESHOLD=0.02

# ============================================================================
# RISK MANAGEMENT & PROFIT TARGETS
# ============================================================================
# Stop loss multiplier for Average True Range
# Stop placed at 1.5x ATR below entry (accounts for volatility)
DEFAULT_STOP_ATR_MULT=1.5

# First take profit risk/reward ratio (1.5 = 1.5:1)
# If risking $100, TP1 targets $150 profit
TP1_RR_RATIO=1.5

# Second take profit risk/reward ratio (2.5 = 2.5:1)
# If risking $100, TP2 targets $250 profit
TP2_RR_RATIO=2.5

# ============================================================================
# SIGNAL MANAGEMENT & FILTERS
# ============================================================================
# Minimum confluence score required for trade signal (5.0 = moderate confidence)
# Higher values = more confluent, fewer false signals
CONFLUENCE_MIN=5.0

# Cooldown period between signals for same symbol (600 = 10 minutes)
# Prevents overtrading and whipsaws from rapid consecutive signals
SIGNAL_COOLDOWN_SECONDS=600

# Signal expiry time window (120 = 2 hours)
# Signal is only valid within this many minutes after generation
SIGNAL_EXPIRY_MINUTES=120

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
